{
  "manifest_version": 3,
  "name": "百度贴吧签到助手",
  "description": "百度贴吧自动签到助手，支持一键签到和后台定时签到",
  "version": "1.0.0",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://tieba.baidu.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "贴吧签到助手",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://tieba.baidu.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
